    Callback = function(v) ANGLE_LERP = v end
})

-- ============================================================
-- ВКЛАДКА: GK STATS — НОВОЕ
-- ============================================================

local StatsTab     = Window:Tab({ Title = "GK Stats", Icon = "bar-chart-2" })
local StatsSection = StatsTab:Section({ Title = "Статистика матча" })

StatsSection:Toggle({
    Title = "Показать Stats GUI",
    Desc = "Отображает сейвы/голы/% в углу экрана",
    Default = false,
    Callback = function(v)
        if v then
            CreateStatsGui()
        else
            pcall(function()
                local old = LocalPlayer.PlayerGui:FindFirstChild("GKStatsGui")
                if old then old:Destroy() end
            end)
            StatsGui = nil
        end
    end
})

StatsSection:Slider({
    Title = "Порог голевой линии (studs)",
    Desc = "На сколько studs мяч должен пройти за ворота",
    Step = 0.5, Value = { Min = 1, Max = 8, Default = 3 },
    Callback = function(v) GOAL_BEHIND_DIST = v end
})

StatsSection:Button({
    Title = "➕ Добавить сейв вручную",
    Desc = "Если авто-подсчёт пропустил",
    Callback = function() CountSave() end
})

StatsSection:Button({
    Title = "➕ Добавить гол вручную",
    Callback = function() CountGoal() end
})

StatsSection:Button({
    Title = "🔄 Сбросить статистику",
    Callback = function()
        ResetStats()
        WindUI:Notify({ Title = "Статистика", Icon = "refresh-cw", Content = "Сброшена!", Duration = 3 })
    end
})

-- ============================================================
-- ВКЛАДКА: BALL PREDICTOR
-- ============================================================

local PredTab     = Window:Tab({ Title = "Ball Predictor", Icon = "activity" })
local PredSection = PredTab:Section({ Title = "Предсказание траектории" })

PredSection:Toggle({
    Title = "Enable Predictor", Desc = "Показывает куда полетит мяч",
    Default = false,
    Callback = function(v) if v then StartPredictor() else StopPredictor() end end
})

-- ============================================================
-- ИНИЦИАЛИЗАЦИЯ
-- ============================================================

CreateHitbox()
UpdateHitbox(false)

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1.5)
    CreateHitbox()
    UpdateHitbox(IsReachEnabled)
    if DiveConn then
        StopAutoDive(); task.wait(0.5); StartAutoDive()
    end
    if AutoPickEnabled then
        StopAutoPickGK(); task.wait(0.2); StartAutoPickGK()
    end
    if AutoPositionEnabled then
        StopAutoPosition(); task.wait(0.2); StartAutoPosition()
    end
    if AutoSaveAngleEnabled then
        StopAutoSaveAngle(); task.wait(0.2); StartAutoSaveAngle()
    end
end)

WindUI:Notify({
    Title = "✅ RSS GK Hub", Icon = "shield",
    Content = "Все фичи загружены! Удачи!", Duration = 4,
})

print("⚽ RSS GK Hub (Full Features v2) загружен!")
