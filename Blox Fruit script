-- FPS МОНИТОР — автоподстройка производительности
-- ═══════════════════════════════════════════════════════════

local frameCount   = 0
local fpsCheckTime = tick()
local currentFPS   = 60

RunService.Heartbeat:Connect(function()
    frameCount += 1
    local elapsed = tick() - fpsCheckTime
    if elapsed >= 2 then
        currentFPS = frameCount / elapsed
        frameCount = 0
        fpsCheckTime = tick()
    end
end)

