    task.delay(duration or 0.4, function()
        if diveIndicator and diveIndicator.Parent then
            diveIndicator.Transparency = 1
        end
    end)
end

local function DestroyDiveIndicator()
    if diveIndicator then
        pcall(function() diveIndicator:Destroy() end)
        diveIndicator = nil
    end
end

