local function CreateHitboxGlow(root)
    if not Settings.EnableVisualEffects or not Settings.EnableHitboxGlow then return end
    if HitboxGlow then pcall(function() HitboxGlow:Destroy() end) end

    HitboxGlow = Instance.new("BoxHandleAdornment")
    HitboxGlow.Name         = "RSSHitboxGlow"
    HitboxGlow.AlwaysOnTop  = false
    HitboxGlow.ZIndex       = 9
    HitboxGlow.Color3       = Color3.fromRGB(0, 180, 80)
    HitboxGlow.Transparency = 1
    HitboxGlow.Size         = HitboxSize + Vector3.new(0.5, 0.5, 0.5)
    HitboxGlow.Adornee      = root
    HitboxGlow.Parent       = Workspace.Terrain
end

local function CreateHitbox()
    if RSSHitbox then
        pcall(function() RSSHitbox:Destroy() end)
        RSSHitbox = nil
    end
    if HitboxGlow then
        pcall(function() HitboxGlow:Destroy() end)
        HitboxGlow = nil
    end

    local root = GetRoot()
    if not root then return end

    RSSHitbox = Instance.new("BoxHandleAdornment")
    RSSHitbox.Name         = "RSSHitbox"
    RSSHitbox.AlwaysOnTop  = false
    RSSHitbox.ZIndex       = 10
    RSSHitbox.Color3       = Color3.fromRGB(0, 255, 100)
    RSSHitbox.Transparency = 1
    RSSHitbox.Size         = HitboxSize
    RSSHitbox.Adornee      = root
    RSSHitbox.Parent       = Workspace.Terrain

    CreateHitboxGlow(root)
end

local function UpdateHitbox(show)
    if not RSSHitbox then return end
    local root = GetRoot()
    if not root then return end
    RSSHitbox.Size    = HitboxSize
    RSSHitbox.Adornee = root

    if show and IsReachEnabled and Settings.EnableVisualEffects then
        RSSHitbox.Transparency = 0.4
        -- Пульсация свечения
        if HitboxGlow and Settings.EnableHitboxGlow then
            HitboxGlow.Size         = HitboxSize + Vector3.new(0.5, 0.5, 0.5)
            HitboxGlow.Adornee      = root
            HitboxGlow.Transparency = 0.6 + math.sin(tick() * 3) * 0.15
        end
    else
        RSSHitbox.Transparency = 1
        if HitboxGlow then HitboxGlow.Transparency = 1 end
    end
end

local function ReachLoop()
    local root = GetRoot()
    if not root or not RSSHitbox then return end
    RSSHitbox.Adornee = root

    local ball = FindBall()
    if not ball then return end

    local char = LocalPlayer.Character
    if not char then return end

    local ballPos = ball.Position
    local reach = math.max(HitboxSize.X, HitboxSize.Y, HitboxSize.Z) / 2
    local distToBall = (ballPos - root.Position).Magnitude

    if distToBall <= reach then
        local parts = {}
        for _, part in ipairs(char:GetChildren()) do
            if part:IsA("BasePart") then
                table.insert(parts, part)
            end
        end
        table.sort(parts, function(a, b)
            return (a.Position - ballPos).Magnitude < (b.Position - ballPos).Magnitude
        end)

        local touchCount = Settings.ReachAggressiveMode and math.min(#parts, 10) or math.min(#parts, Settings.ReachTouchCount)
        local touched = false

        for i, part in ipairs(parts) do
            if i > touchCount then break end
            -- Тройной touch для надёжности
            pcall(firetouchinterest, part, ball, 0)
            pcall(firetouchinterest, part, ball, 1)
            pcall(firetouchinterest, part, ball, 0)
            pcall(firetouchinterest, part, ball, 1)

            if Settings.ReachAggressiveMode then
                -- Доп. касание в агрессивном режиме
                pcall(firetouchinterest, part, ball, 0)
                pcall(firetouchinterest, part, ball, 1)
            end
            touched = true
        end

        if touched then
            Stats.BallsTouched += 1
        end

        -- Обновляем хитбокс с пульсацией при касании
        if Settings.EnableVisualEffects and Settings.EnableHitboxGlow and HitboxGlow then
            HitboxGlow.Color3 = Color3.fromRGB(255, 255, 0)
            task.delay(0.1, function()
                if HitboxGlow and HitboxGlow.Parent then
                    HitboxGlow.Color3 = Color3.fromRGB(0, 180, 80)
                end
            end)
        end
    end
end

local hitboxPulseConn = nil

local function EnableReach()
    if ReachConn then return end
    IsReachEnabled = true
    if not RSSHitbox then CreateHitbox() end

    -- Основной цикл reach
    ReachConn = RunService.Heartbeat:Connect(ReachLoop)

    -- Пульсация хитбокса
    if Settings.EnableVisualEffects then
        if hitboxPulseConn then hitboxPulseConn:Disconnect() end
        hitboxPulseConn = RunService.Heartbeat:Connect(function()
            if IsReachEnabled and HitboxGlow and HitboxGlow.Parent then
                HitboxGlow.Size = HitboxSize + Vector3.new(0.5, 0.5, 0.5) * (1 + math.sin(tick() * 2) * 0.3)
                HitboxGlow.Transparency = 0.55 + math.sin(tick() * 3) * 0.15
            end
        end)
    end
end

local function DisableReach()
    if ReachConn then ReachConn:Disconnect(); ReachConn = nil end
    if hitboxPulseConn then hitboxPulseConn:Disconnect(); hitboxPulseConn = nil end
    IsReachEnabled = false
    UpdateHitbox(false)
end

