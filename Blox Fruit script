local function StartPredictor()
    local cfg = {
        gravity       = 196.2,
        bounceDamping = 0.68,
        groundHeight  = 0,
        airResistance = 0.99,
        friction      = 0.85,
        segmentTrans  = 0.25,
        dt            = 0.04,
        colorCurve    = Color3.fromRGB(0, 220, 255),
        colorLand     = Color3.fromRGB(255, 220, 0),
    }

    if curveFolder then
        pcall(function() curveFolder:Destroy() end)
        curveFolder = nil
    end
    curveFolder        = Instance.new("Folder")
    curveFolder.Name   = "GK_Predictor"
    curveFolder.Parent = Workspace

    local segs = {}
    for i = 1, Settings.PredictorSegments do
        local s = Instance.new("Part")
        s.Anchored     = true
        s.CanCollide   = false
        s.CastShadow   = false
        s.Material     = Enum.Material.Neon
        s.Color        = cfg.colorCurve
        s.Transparency = 1
        s.Size         = Vector3.new(0.25, 0.25, 1)
        s.Parent       = curveFolder
        segs[i] = s
    end

    local marker = Instance.new("Part")
    marker.Anchored    = true
    marker.CanCollide  = false
    marker.CastShadow  = false
    marker.Material    = Enum.Material.Neon
    marker.Color       = cfg.colorLand
    marker.Transparency = 1
    marker.Size        = Vector3.new(5, 0.15, 5)
    marker.Shape       = Enum.PartType.Cylinder
    marker.Parent      = curveFolder

    local function Simulate(startPos, startVel)
        local pts     = {}
        local pos     = startPos
        local vel     = startVel
        local gdt     = Vector3.new(0, -cfg.gravity * cfg.dt, 0)
        local bounces = 0
        local maxSteps = math.floor(Settings.PredictorMaxTime / cfg.dt)

        for step = 1, maxSteps do
            vel = (vel + gdt) * cfg.airResistance
            pos = pos + vel * cfg.dt
            pts[step] = pos

            if pos.Y <= cfg.groundHeight and vel.Y < 0 then
                pos = Vector3.new(pos.X, cfg.groundHeight, pos.Z)
                vel = Vector3.new(vel.X * cfg.friction, -vel.Y * cfg.bounceDamping, vel.Z * cfg.friction)
                bounces += 1
                if bounces >= 3 or vel.Magnitude < 2 then break end
            end
            if vel.Magnitude < 0.5 then break end
        end
        return pts
    end

    local frame = 0
    predConn = RunService.Heartbeat:Connect(function()
        frame += 1

        -- ★ Частота обновления из настроек
        local updateRate = Settings.PerformanceMode
            and math.max(Settings.PredictorUpdateRate, 5)
            or Settings.PredictorUpdateRate
        if frame % updateRate ~= 0 then return end

        local ball = FindBall()
        if not ball or ball.AssemblyLinearVelocity.Magnitude < Settings.PredictorMinSpeed then
            for _, s in ipairs(segs) do s.Transparency = 1 end
            marker.Transparency = 1
            return
        end

        local pts = Simulate(ball.Position, ball.AssemblyLinearVelocity)
        local n   = #pts
        if n < 2 then
            for _, s in ipairs(segs) do s.Transparency = 1 end
            marker.Transparency = 1
            return
        end

        -- ★ Линия траектории — учитываем настройку
        local segCount = math.min(#segs, Settings.PredictorSegments)
        local step = (n - 1) / segCount

        for i = 1, #segs do
            if i > segCount or not Settings.PredictorLine then
                segs[i].Transparency = 1
            else
                local idx  = math.floor((i - 1) * step) + 1
                local idx2 = math.min(idx + 1, n)
                local p1, p2 = pts[idx], pts[idx2]
                local dist = (p2 - p1).Magnitude
                if dist > 0.01 then
                    segs[i].Size   = Vector3.new(0.25, 0.25, dist)
                    segs[i].CFrame = CFrame.lookAt((p1 + p2) * 0.5, p2)
                    -- ★ Градиент прозрачности
                    if Settings.PredictorGradient then
                        segs[i].Transparency = cfg.segmentTrans + (i / segCount) * 0.35
                    else
                        segs[i].Transparency = cfg.segmentTrans
                    end
                else
                    segs[i].Transparency = 1
                end
            end
        end

        -- ★ Метка приземления — учитываем настройку
        if not Settings.PredictorLandMark then
            marker.Transparency = 1
        else
            local landPos = nil
            for i = 2, n do
                if pts[i].Y <= cfg.groundHeight + 0.3 and pts[i-1].Y > cfg.groundHeight + 0.3 then
                    local dy = pts[i].Y - pts[i-1].Y
                    if math.abs(dy) > 0.001 then
                        local t = math.clamp((cfg.groundHeight - pts[i-1].Y) / dy, 0, 1)
                        landPos = pts[i-1]:Lerp(pts[i], t)
                    end
                    break
                end
            end

            if landPos then
                -- ★ Пульсация — учитываем настройку
                local size
                if Settings.PredictorPulse then
                    size = 5 + math.sin(tick() * 4) * 1.5
                else
                    size = 5
                end
                marker.Size        = Vector3.new(size, 0.15, size)
                marker.CFrame      = CFrame.new(landPos + Vector3.new(0, 0.1, 0)) * CFrame.Angles(0, 0, math.pi / 2)
                marker.Transparency = 0.35
            else
                marker.Transparency = 1
            end
        end
    end)

    Notify("✅ Предиктор", "activity", "Предиктор траектории включён", 2)
end

local function StopPredictor()
    if predConn then predConn:Disconnect(); predConn = nil end
    if curveFolder then
        pcall(function() curveFolder:Destroy() end)
        curveFolder = nil
    end
    Notify("❌ Предиктор", "activity", "Предиктор выключен", 2)
end

