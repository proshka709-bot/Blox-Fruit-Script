    Title    = "Auto Dive",
    Desc     = "Полностью автоматический дайв. Чувствительность, дистанция, кулдаун — всё адаптивно.",
    Default  = false,
    Callback = function(v)
        if v then StartAutoDive() else StopAutoDive() end
    end
})

-- ──────── ВКЛАДКА: PREDICTOR ────────

local PredTab     = Window:Tab({ Title = "Predictor", Icon = "activity" })
local PredSection = PredTab:Section({ Title = "Траектория мяча" })

PredSection:Toggle({
    Title    = "Ball Predictor",
    Desc     = "Предсказание траектории с учётом spin, гравитации и отскоков. Настройки автоматические по FPS.",
