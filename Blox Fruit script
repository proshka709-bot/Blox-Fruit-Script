-- ============================================================
-- AUTO POSITION — НОВОЕ
-- ============================================================

local function StartAutoPosition()
    if AutoPositionConn then AutoPositionConn:Disconnect(); AutoPositionConn = nil end
    local root = GetRoot()
    if not root then return end
    GoalLineZ = root.Position.Z
    AutoPositionEnabled = true

    AutoPositionConn = RunService.Heartbeat:Connect(function()
        if not AutoPositionEnabled then return end
        local r    = GetRoot()
        local ball = FindBall()
        if not r or not ball then return end
        local targetX = math.clamp(ball.Position.X * 0.35, -GOAL_HALF_WIDTH, GOAL_HALF_WIDTH)
        local cur     = r.Position
        local newX    = cur.X + (targetX - cur.X) * POSITION_LERP
        local _, ry, _ = r.CFrame:ToEulerAnglesYXZ()
        r.CFrame = CFrame.new(newX, cur.Y, GoalLineZ) * CFrame.Angles(0, ry, 0)
    end)
end

local function StopAutoPosition()
    AutoPositionEnabled = false
    if AutoPositionConn then AutoPositionConn:Disconnect(); AutoPositionConn = nil end
end

-- ============================================================
-- AUTO SAVE ANGLE — НОВОЕ
-- ============================================================

local function StartAutoSaveAngle()
    if AutoSaveAngleConn then AutoSaveAngleConn:Disconnect(); AutoSaveAngleConn = nil end
    AutoSaveAngleEnabled = true

    AutoSaveAngleConn = RunService.Heartbeat:Connect(function()
        if not AutoSaveAngleEnabled then return end
        local r    = GetRoot()
        local ball = FindBall()
        if not r or not ball then return end
        local vel = ball.AssemblyLinearVelocity
        if vel.Magnitude < 6 then return end
        local dz = r.Position.Z - ball.Position.Z
        if math.abs(vel.Z) < 0.5 then return end
        local comingToUs = (dz > 0 and vel.Z > 0) or (dz < 0 and vel.Z < 0)
        if not comingToUs then return end
        local timeToGoal = dz / vel.Z
        if timeToGoal < 0 or timeToGoal > 2.5 then return end
        local predictedX = math.clamp(ball.Position.X + vel.X * timeToGoal, -GOAL_HALF_WIDTH, GOAL_HALF_WIDTH)
        local cur  = r.Position
        local newX = cur.X + (predictedX - cur.X) * ANGLE_LERP
        local _, ry, _ = r.CFrame:ToEulerAnglesYXZ()
        r.CFrame = CFrame.new(newX, cur.Y, cur.Z) * CFrame.Angles(0, ry, 0)
    end)
end

local function StopAutoSaveAngle()
    AutoSaveAngleEnabled = false
    if AutoSaveAngleConn then AutoSaveAngleConn:Disconnect(); AutoSaveAngleConn = nil end
end

-- ============================================================
-- AUTO DIVE + AUTO JUMP + SMART DIRECTION
-- ============================================================

local function PredictBallPos(ball, dt)
    local vel     = ball.AssemblyLinearVelocity
    local pos     = ball.Position
    local gravity = Vector3.new(0, -196.2, 0)
    return pos + vel * dt + gravity * (dt * dt * 0.5)
end

-- НОВОЕ: ближайший к мячу игрок (бьющий)
local function GetNearestShooterPos()
    local ball = FindBall()
    if not ball then return nil end
    local nearest, nearestDist = nil, 12
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local pr = plr.Character:FindFirstChild("HumanoidRootPart")
            if pr then
                local d = (pr.Position - ball.Position).Magnitude
                if d < nearestDist then nearestDist = d; nearest = pr.Position end
            end
        end
    end
    return nearest
end

local function GetDiveButtons()
    local ok1, l1, r1 = pcall(function()
        local gui   = LocalPlayer:FindFirstChild("PlayerGui")
        local ctrl  = gui and gui:FindFirstChild("MobileCTRL")
        local frame = ctrl and ctrl:FindFirstChild("TouchControlFrame")
        local jump  = frame and frame:FindFirstChild("JumpButton")
        if not jump then return nil, nil end
        return jump:FindFirstChild("LeftDive"), jump:FindFirstChild("RightDive")
    end)
    if ok1 and l1 and r1 then return l1, r1 end

    local ok2, l2, r2 = pcall(function()
        local gui = LocalPlayer:FindFirstChild("PlayerGui")
        if not gui then return nil, nil end
        local leftBtn, rightBtn
        for _, obj in ipairs(gui:GetDescendants()) do
            if obj.Name == "LeftDive"  then leftBtn  = obj end
            if obj.Name == "RightDive" then rightBtn = obj end
        end
        return leftBtn, rightBtn
    end)
    if ok2 and l2 and r2 then return l2, r2 end
    return nil, nil
end

local function GetJumpButton()
    local ok, btn = pcall(function()
        local gui = LocalPlayer:FindFirstChild("PlayerGui")
        if not gui then return nil end
        for _, obj in ipairs(gui:GetDescendants()) do
            if obj.Name == "JumpButton" and obj:IsA("ImageButton") then return obj end
        end
        return nil
    end)
    return ok and btn or nil
end

local function FireButton(btn)
    if not btn then return end
    local ok, conns = pcall(getconnections, btn.MouseButton1Click)
    if ok and conns and #conns > 0 then
        pcall(function() conns[1]:Fire() end)
        return
    end
    pcall(function() btn.MouseButton1Click:Fire() end)
end

local function TriggerJump(jumpBtn)
    if jumpBtn then FireButton(jumpBtn) end
    pcall(function()
        local char = LocalPlayer.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if hum then hum.Jump = true end
    end)
end

local function StartAutoDive()
    if DiveConn then DiveConn:Disconnect(); DiveConn = nil end
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp  = char:WaitForChild("HumanoidRootPart")

    local leftBtn, rightBtn, jumpBtn = nil, nil, nil

    task.spawn(function()
        for attempt = 1, 15 do
            leftBtn, rightBtn = GetDiveButtons()
            jumpBtn = GetJumpButton()
            if leftBtn and rightBtn then
                print("✅ Кнопки дайва найдены с попытки #" .. attempt)
                break
            end
            task.wait(1)
        end
        if not leftBtn or not rightBtn then warn("❌ Кнопки дайва не найдены!") end
    end)

    local prevVelZ   = 0
    local diveFired  = false
    local diveFireTick = 0

    DiveConn = RunService.Heartbeat:Connect(function()
        if not leftBtn or not rightBtn then return end
        local ball = FindBall()
        if not ball then prevVelZ = 0; return end

        local now  = tick()
        local vel  = ball.AssemblyLinearVelocity
        local dist = (ball.Position - hrp.Position).Magnitude

        -- АВТО-СЕЙВ: смена направления Z после дайва
        if diveFired and (now - diveFireTick) < 1.0 then
            if prevVelZ ~= 0 and vel.Z ~= 0 and ((prevVelZ > 0) ~= (vel.Z > 0)) then
                CountSave(); diveFired = false
            end
        elseif diveFired and (now - diveFireTick) >= 1.0 then
            diveFired = false
        end

        -- АВТО-ГОЛ: мяч прошёл за линию ворот
        local r = GetRoot()
        if r and GoalLineZ then
            local behind     = r.Position.Z - GoalLineZ
            local ballBehind = ball.Position.Z - GoalLineZ
            local goalCrossed = (behind > 0 and ballBehind > GOAL_BEHIND_DIST)
                             or (behind < 0 and ballBehind < -GOAL_BEHIND_DIST)
            if goalCrossed and vel.Magnitude > 5 and (now - lastDiveTime) > 3 then
                CountGoal(); lastDiveTime = now
            end
        end

        prevVelZ = vel.Z

        if now - lastDiveTime < DIVE_COOLDOWN then return end
        if dist > DIVE_DIST then return end
        if vel.Magnitude < 3 then return end

        local ballHeight = ball.Position.Y - hrp.Position.Y

        -- AUTO JUMP: мяч летит высоко
        if AutoJumpEnabled and ballHeight > JUMP_HEIGHT_THRESH then
            local predHigh = PredictBallPos(ball, 0.25)
            if (predHigh - hrp.Position).Magnitude < DIVE_DIST then
                lastDiveTime = now
                TriggerJump(jumpBtn)
                print("⬆ Прыжок! H=" .. math.floor(ballHeight))
                return
            end
        end

        if ballHeight > 6 then return end

        -- SMART DIVE: предсказание + бьющий (60/40)
        local predictTime = math.clamp(dist / math.max(vel.Magnitude, 1), 0.1, 0.6)
        local predicted   = PredictBallPos(ball, predictTime)
        local shooterPos  = GetNearestShooterPos()
        local finalX

        if shooterPos then
            local sLocal = hrp.CFrame:PointToObjectSpace(shooterPos)
            local bLocal = hrp.CFrame:PointToObjectSpace(predicted)
            finalX = bLocal.X * 0.6 + sLocal.X * 0.4
        else
            finalX = hrp.CFrame:PointToObjectSpace(predicted).X
        end

        local threshold = 0.8
        if finalX < -threshold then
            lastDiveTime = now; diveFired = true; diveFireTick = now
            FireButton(leftBtn)
            print("◀ Влево | Smart | d=" .. math.floor(dist) .. " v=" .. math.floor(vel.Magnitude))
        elseif finalX > threshold then
            lastDiveTime = now; diveFired = true; diveFireTick = now
            FireButton(rightBtn)
            print("▶ Вправо | Smart | d=" .. math.floor(dist) .. " v=" .. math.floor(vel.Magnitude))
        end
    end)

    print("✅ Auto Dive (Full) ВКЛЮЧЁН | Радиус: " .. DIVE_DIST)
end

local function StopAutoDive()
    if DiveConn then DiveConn:Disconnect(); DiveConn = nil end
    print("Auto Dive ОТКЛЮЧЁН")
end

-- ============================================================
-- BALL PREDICTOR
-- ============================================================

local predConn    = nil
local curveFolder = nil

local function StartPredictor()
    local cfg = {
        gravity = 196.2, bounceDamping = 0.68, groundHeight = 0,
        airResistance = 0.99, friction = 0.85, segmentCount = 20,
        segmentTrans = 0.25, maxTime = 8, dt = 0.04, minSpeed = 3,
        updateEvery = 3, colorCurve = Color3.fromRGB(0, 220, 255),
        colorLand = Color3.fromRGB(255, 220, 0),
    }
    if curveFolder then curveFolder:Destroy() end
    curveFolder = Instance.new("Folder")
    curveFolder.Name = "GK_Predictor"; curveFolder.Parent = Workspace

    local segs = {}
    for i = 1, cfg.segmentCount do
        local s = Instance.new("Part")
        s.Anchored = true; s.CanCollide = false; s.CastShadow = false
        s.Material = Enum.Material.Neon; s.Color = cfg.colorCurve
        s.Transparency = 1; s.Size = Vector3.new(0.25, 0.25, 1)
        s.Parent = curveFolder; segs[i] = s
    end

    local marker = Instance.new("Part")
    marker.Anchored = true; marker.CanCollide = false; marker.CastShadow = false
    marker.Material = Enum.Material.Neon; marker.Color = cfg.colorLand
    marker.Transparency = 1; marker.Size = Vector3.new(5, 0.15, 5)
    marker.Shape = Enum.PartType.Cylinder; marker.Parent = curveFolder

    local function Simulate(startPos, startVel)
        local pts, pos, vel = {}, startPos, startVel
        local gdt = Vector3.new(0, -cfg.gravity * cfg.dt, 0)
        local bounces = 0
        for _ = 1, math.floor(cfg.maxTime / cfg.dt) do
            vel = (vel + gdt) * cfg.airResistance
            pos = pos + vel * cfg.dt
            table.insert(pts, pos)
            if pos.Y <= cfg.groundHeight and vel.Y < 0 then
                pos = Vector3.new(pos.X, cfg.groundHeight, pos.Z)
                vel = Vector3.new(vel.X * cfg.friction, -vel.Y * cfg.bounceDamping, vel.Z * cfg.friction)
                bounces += 1
                if bounces >= 3 or vel.Magnitude < 2 then break end
            end
        end
        return pts
    end

    local frame = 0
    predConn = RunService.Heartbeat:Connect(function()
        frame += 1
        if frame % cfg.updateEvery ~= 0 then return end
        local ball = FindBall()
        if not ball or ball.AssemblyLinearVelocity.Magnitude < cfg.minSpeed then
            for _, s in ipairs(segs) do s.Transparency = 1 end
            marker.Transparency = 1; return
        end
        local pts = Simulate(ball.Position, ball.AssemblyLinearVelocity)
        local n   = #pts
        if n < 2 then return end
        local step = (n - 1) / cfg.segmentCount
        for i = 1, cfg.segmentCount do
            local idx  = math.floor((i - 1) * step) + 1
            local idx2 = math.min(idx + 1, n)
            local p1, p2 = pts[idx], pts[idx2]
            local d = (p2 - p1).Magnitude
            if d > 0.01 then
                segs[i].Size = Vector3.new(0.25, 0.25, d)
                segs[i].CFrame = CFrame.lookAt((p1 + p2) * 0.5, p2)
                segs[i].Transparency = cfg.segmentTrans
            else segs[i].Transparency = 1 end
        end
        local landPos = nil
        for i = 2, n do
            if pts[i].Y <= cfg.groundHeight + 0.3 and pts[i-1].Y > cfg.groundHeight + 0.3 then
                local t = math.clamp((cfg.groundHeight - pts[i-1].Y) / (pts[i].Y - pts[i-1].Y), 0, 1)
                landPos = pts[i-1]:Lerp(pts[i], t); break
            end
        end
        if landPos then
            local pulse = 5 + math.sin(tick() * 4) * 1.5
            marker.Size = Vector3.new(pulse, 0.15, pulse)
            marker.CFrame = CFrame.new(landPos + Vector3.new(0, 0.1, 0)) * CFrame.Angles(0, 0, math.pi / 2)
            marker.Transparency = 0.35
        else marker.Transparency = 1 end
    end)
end

local function StopPredictor()
    if predConn    then predConn:Disconnect(); predConn = nil end
    if curveFolder then curveFolder:Destroy(); curveFolder = nil end
end

