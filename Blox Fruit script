-- ИНИЦИАЛИЗАЦИЯ
-- ═══════════════════════════════════════════════════════════

CreateHitbox()
UpdateHitbox()

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1.5)
    cachedBall = nil

    CreateHitbox()
    UpdateHitbox()

    -- Перезапуск Reach после респавна
    if IsReachEnabled then
        if ReachConn then ReachConn:Disconnect(); ReachConn = nil end
        if hitboxPulseConn then hitboxPulseConn:Disconnect(); hitboxPulseConn = nil end
        EnableReach()
    end

    -- Перезапуск Auto Dive после респавна
    if DiveActive then
        if DiveConn then DiveConn:Disconnect(); DiveConn = nil end
        task.wait(0.5)
        StartAutoDive()
    end
end)

SafeNotify({
    Title    = "✅ RSS GK Hub",
    Icon     = "shield",
    Content  = "Загружен! Все параметры настраиваются автоматически.",
    Duration = 5,
})

print("[RSS GK] Smart Edition загружен!")
