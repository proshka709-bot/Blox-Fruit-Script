-- Предсказание позиции мяча через dt секунд
local function PredictBallPos(ball, dt)
    local vel = ball.AssemblyLinearVelocity
    local pos = ball.Position
    local g   = Vector3.new(0, -196.2, 0)
    return pos + vel * dt + g * (dt * dt * 0.5)
end

local function GetDiveButtons()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    if not gui then return nil, nil end

    local leftBtn, rightBtn
    local ok1 = pcall(function()
        local ctrl  = gui:FindFirstChild("MobileCTRL")
        local frame = ctrl and ctrl:FindFirstChild("TouchControlFrame")
        local jump  = frame and frame:FindFirstChild("JumpButton")
        if jump then
            leftBtn  = jump:FindFirstChild("LeftDive")
            rightBtn = jump:FindFirstChild("RightDive")
        end
    end)
    if ok1 and leftBtn and rightBtn then return leftBtn, rightBtn end

    leftBtn, rightBtn = nil, nil
    pcall(function()
        for _, obj in ipairs(gui:GetDescendants()) do
            if obj.Name == "LeftDive" and not leftBtn then leftBtn = obj end
            if obj.Name == "RightDive" and not rightBtn then rightBtn = obj end
            if leftBtn and rightBtn then break end
        end
    end)
    return leftBtn, rightBtn
end

local function FireButton(btn)
    if not btn then return end
    local ok, conns = pcall(getconnections, btn.MouseButton1Click)
    if ok and conns then
        for _, conn in ipairs(conns) do
            pcall(function() conn:Fire() end)
        end
        if #conns > 0 then return end
    end
    pcall(function() btn.MouseButton1Click:Fire() end)
end

local function TryJump()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and hum:GetState() ~= Enum.HumanoidStateType.Jumping
          and hum:GetState() ~= Enum.HumanoidStateType.Freefall then
        hum.Jump = true
    end
end

-- Определяет: это удар (шот) или просто катящийся мяч?
local function IsShot(ball, hrp)
    local vel    = ball.AssemblyLinearVelocity
    local velMag = vel.Magnitude

    -- Слишком медленный мяч — это не удар
    if velMag < 12 then return false end

    -- Горизонтальная скорость (без Y)
    local horizVel = Vector3.new(vel.X, 0, vel.Z)
    local horizMag = horizVel.Magnitude

    -- Если мяч по земле и медленнее 20 — это просто катится
    local ballHeight = ball.Position.Y - hrp.Position.Y
    if ballHeight < 1.5 and horizMag < 20 then return false end

    -- Направление мяча к вратарю
    local toGK    = (hrp.Position - ball.Position)
    local toGKDir = Vector3.new(toGK.X, 0, toGK.Z)
    if toGKDir.Magnitude < 0.1 then return true end -- мяч прямо на нас
    toGKDir = toGKDir.Unit

    local velDir = Vector3.new(vel.X, 0, vel.Z)
    if velDir.Magnitude < 0.1 then return false end
    velDir = velDir.Unit

    -- Мяч должен лететь в нашу сторону (dot > 0.15)
    local dot = toGKDir:Dot(velDir)
    if dot < 0.15 then return false end

    return true
end

local prevBallVel    = nil
local prevBallSpeed  = 0

local function StartAutoDive()
    if DiveConn then DiveConn:Disconnect(); DiveConn = nil end
    DiveActive   = true
    prevBallVel  = nil
    prevBallSpeed = 0

    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp  = char:WaitForChild("HumanoidRootPart", 5)
    if not hrp then
        warn("❌ HumanoidRootPart не найден!")
        DiveActive = false
        return
    end

    local leftBtn  = nil
    local rightBtn = nil

    task.spawn(function()
        for attempt = 1, 20 do
            leftBtn, rightBtn = GetDiveButtons()
            if leftBtn and rightBtn then
                print("✅ Кнопки дайва найдены с попытки #" .. attempt)
                break
            end
            task.wait(0.8)
        end
        if not leftBtn or not rightBtn then
            warn("❌ Кнопки дайва не найдены!")
        end
    end)

    DiveConn = RunService.Heartbeat:Connect(function()
        if not leftBtn or not rightBtn then return end
        if not hrp or not hrp.Parent then return end

        local ball = FindBall()
        if not ball then prevBallVel = nil; prevBallSpeed = 0; return end

        local vel    = ball.AssemblyLinearVelocity
        local velMag = vel.Magnitude

        -- Детекция удара: резкий рост скорости = кто-то ударил
        local wasKicked = false
        if prevBallVel then
            local speedJump = velMag - prevBallSpeed
            local accel     = (vel - prevBallVel).Magnitude
            if accel > 12 or speedJump > 10 then
                wasKicked = true
            end
        end
        prevBallVel   = vel
        prevBallSpeed = velMag

        -- ★ ГЛАВНЫЙ ФИЛЬТР: это удар или просто катящийся мяч?
        if not IsShot(ball, hrp) then return end

        local now = tick()
        -- Кулдаун: 0.25 сек обычно, 0.12 сек при обнаруженном ударе
        local cooldown = wasKicked and 0.12 or 0.25
        if now - lastDiveTime < cooldown then return end

        local ballPos = ball.Position
        local hrpPos  = hrp.Position
        local dist    = (ballPos - hrpPos).Magnitude

        -- Авто-дистанция: зависит от скорости мяча
        -- Быстрый мяч = реагируем раньше (дальше)
        local maxDist = math.clamp(8 + velMag * 0.25, 12, 30)
        if dist > maxDist then return end

        -- Время до прилёта мяча к нам
        local timeToArrive = dist / math.max(velMag, 1)

        -- Предсказание: куда мяч будет когда долетит
        local predictTime = math.clamp(timeToArrive, 0.05, 0.5)
        local predicted   = PredictBallPos(ball, predictTime)
        local localPred   = hrp.CFrame:PointToObjectSpace(predicted)

        -- Высота предсказанной точки
        local predHeight = predicted.Y - hrpPos.Y
        if predHeight > 8 then return end -- слишком высоко

        lastDiveTime = now

        -- Высокий мяч: прыжок
        if predHeight > 1.5 then
            TryJump()
        end

        -- Порог стороны: чем быстрее мяч, тем быстрее дайвим
        -- При очень быстром мяче дайвим почти при любом смещении
        local sideThreshold = math.clamp(0.6 - (velMag / 200), 0.1, 0.6)

        if localPred.X < -sideThreshold then
            FireButton(leftBtn)
        elseif localPred.X > sideThreshold then
            FireButton(rightBtn)
        else
            -- Мяч по центру — прыжок + обе кнопки
            if velMag > 15 then
                TryJump()
                FireButton(leftBtn)
                FireButton(rightBtn)
            end
        end
    end)

    print("✅ Auto Dive 7v7 ВКЛЮЧЁН")
end

local function StopAutoDive()
    DiveActive = false
    if DiveConn then DiveConn:Disconnect(); DiveConn = nil end
    prevBallVel  = nil
    prevBallSpeed = 0
    print("Auto Dive ОТКЛЮЧЁН")
end

