--[[
    ⚽ RSS GK HUB — 7v7 УЛУЧШЕННЫЙ v3.3 (MOBILE EDITION)
    ★ FrontDive для центральных мячей
    ★ Ползунок дистанции: скрипт реагирует только если мяч близко
    ★ Авто-прыжок для высоких мячей по центру
    ★ НОВОЕ: Вкладка Нападающий — AutoShoot, AutoDeke, AutoTackle
]]

local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local Workspace         = game:GetService("Workspace")
local Stats             = game:GetService("Stats")
local LocalPlayer       = Players.LocalPlayer

-- ============================================================
-- НАСТРОЙКИ
-- ============================================================
local Settings = {
    DiveReactionTime    = 0.40,
    DiveAutoJump        = true,
    PingCompensation    = true,
    DiveMaxDistance     = 40,        -- Максимальная дистанция до мяча (в стадах) при которой скрипт реагирует

    HitboxSize          = Vector3.new(12, 10, 12),
    HitboxGlow          = true,

    PredictorLine       = true,
    PredictorLandMark   = true,
}

-- ============================================================
-- СОСТОЯНИЕ
-- ============================================================
local ReachConn         = nil
local RSSHitbox         = nil
local DiveConn          = nil
local lastDiveTime      = 0
local predConn          = nil
local curveFolder       = nil
local cachedBall        = nil

local BALL_NAMES = {"ball", "TPS", "PSoccerBall", "Soccer Ball", "Football", "SoccerBall", "Ball", "soccer_ball"}

-- ============================================================
-- БАЗОВЫЕ ФУНКЦИИ
-- ============================================================
local function GetRoot()
    return LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
end

local function GetHumanoid()
    return LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
end

local function FindBall()
    if cachedBall and cachedBall.Parent then return cachedBall end
    for _, name in ipairs(BALL_NAMES) do
        local b = Workspace:FindFirstChild(name, true)
        if b and b:IsA("BasePart") then
            cachedBall = b; return b
        end
    end
    return nil
end

local function GetPing()
    if not Settings.PingCompensation then return 0 end
    local success, ping = pcall(function()
        return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
    end)
    return success and (math.clamp(ping, 0, 300) / 1000) or 0.05
end

-- ============================================================
-- HITBOX / REACH
-- ============================================================
local function UpdateHitbox(show)
    if RSSHitbox then RSSHitbox:Destroy() end
    local root = GetRoot()
    if not root or not show then return end

    RSSHitbox              = Instance.new("BoxHandleAdornment")
    RSSHitbox.Name         = "RSSHitbox"
    RSSHitbox.ZIndex       = 10
    RSSHitbox.Color3       = Color3.fromRGB(0, 255, 100)
    RSSHitbox.Transparency = Settings.HitboxGlow and 0.5 or 1
    RSSHitbox.Size         = Settings.HitboxSize
    RSSHitbox.Adornee      = root
    RSSHitbox.Parent       = Workspace.Terrain
end

local function ReachLoop()
    local root = GetRoot()
    local ball = FindBall()
    if not root or not ball then return end

    local dist = (ball.Position - root.Position).Magnitude
    if dist > (Settings.HitboxSize.X / 1.5) then return end

    local parts = {root, LocalPlayer.Character:FindFirstChild("Torso"), LocalPlayer.Character:FindFirstChild("UpperTorso")}
    for _, part in ipairs(parts) do
        if part then
            pcall(firetouchinterest, part, ball, 0)
            pcall(firetouchinterest, part, ball, 1)
        end
    end
end

-- ============================================================
-- AUTO DIVE — v3.2
-- Кнопки: LeftDive / RightDive / FrontDive (родитель: JumpButton)
-- Прыжок: стандартный Humanoid.Jump для высоких мячей
-- ============================================================

local function FireButton(btnName)
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    if not gui then return end
    pcall(function()
        for _, obj in ipairs(gui:GetDescendants()) do
            if obj.Name == btnName and obj:IsA("GuiButton") then
                for _, conn in ipairs(getconnections(obj.MouseButton1Click)) do conn:Fire() end
                for _, conn in ipairs(getconnections(obj.TouchTap)) do conn:Fire() end
                break
            end
        end
    end)
end

local function DoJump()
    local hum = GetHumanoid()
    if hum and hum:GetState() ~= Enum.HumanoidStateType.Jumping then
        hum.Jump = true
    end
end

local function TriggerDive(direction, isHigh)
    if direction == "Left" then
        if isHigh then DoJump() end
        FireButton("LeftDive")
    elseif direction == "Right" then
        if isHigh then DoJump() end
        FireButton("RightDive")
    elseif direction == "Front" then
        FireButton("FrontDive")
    elseif direction == "Jump" then
        DoJump()
    end
end

local function StartAutoDive()
    if DiveConn then DiveConn:Disconnect() end

    DiveConn = RunService.Heartbeat:Connect(function()
        local hrp = GetRoot()
        local ball = FindBall()
        if not hrp or not ball then return end

        -- Проверка дистанции — ползунок в меню
        local distance = (ball.Position - hrp.Position).Magnitude
        if distance > Settings.DiveMaxDistance then return end

        local vel = ball.AssemblyLinearVelocity
        local speed = vel.Magnitude
        if speed < 15 then return end

        -- Летит ли мяч в нашу сторону?
        local toPlayer = hrp.Position - ball.Position
        if toPlayer.Unit:Dot(vel.Unit) < 0.3 then return end

        local timeToImpact = distance / speed
        local ping = GetPing()
        local reactionWindow = Settings.DiveReactionTime + ping

        if timeToImpact <= reactionWindow then
            local now = tick()
            if now - lastDiveTime < 0.5 then return end
            lastDiveTime = now

            -- Предсказываем куда прилетит мяч
            local predictedPos = ball.Position + (vel * timeToImpact)
            local localPredicted = hrp.CFrame:PointToObjectSpace(predictedPos)

            local isHigh   = localPredicted.Y > 2.5   -- высокий мяч
            local isCenter = math.abs(localPredicted.X) <= 1.5  -- по центру

            if localPredicted.X < -1.5 then
                -- Влево
                TriggerDive("Left", isHigh)
            elseif localPredicted.X > 1.5 then
                -- Вправо
                TriggerDive("Right", isHigh)
            elseif isCenter and isHigh then
                -- Центр + высоко → прыжок
                TriggerDive("Jump", false)
            elseif isCenter then
                -- Центр + низко/средне → FrontDive
                TriggerDive("Front", false)
            end
        end
    end)
end

-- ============================================================
-- BALL PREDICTOR
-- ============================================================
local function StartPredictor()
    if curveFolder then curveFolder:Destroy() end
    curveFolder = Instance.new("Folder", Workspace)

    local segs = {}
    for i = 1, 15 do
        local s = Instance.new("Part", curveFolder)
        s.Anchored, s.CanCollide, s.CastShadow = true, false, false
        s.Material = Enum.Material.Neon
        s.Color = Color3.fromRGB(0, 220, 255)
        s.Size = Vector3.new(0.2, 0.2, 1)
        s.Transparency = 1
        segs[i] = s
    end

    local marker = Instance.new("Part", curveFolder)
    marker.Anchored, marker.CanCollide = true, false
    marker.Material, marker.Color = Enum.Material.Neon, Color3.fromRGB(255, 220, 0)
    marker.Size = Vector3.new(4, 0.15, 4)
    marker.Shape = Enum.PartType.Cylinder
    marker.Transparency = 1

    predConn = RunService.Heartbeat:Connect(function()
        local ball = FindBall()
        if not ball or ball.AssemblyLinearVelocity.Magnitude < 5 then
            for _, s in ipairs(segs) do s.Transparency = 1 end
            marker.Transparency = 1; return
        end

        local pos = ball.Position
        local vel = ball.AssemblyLinearVelocity
        local dt = 0.05
        local g = Vector3.new(0, -196.2 * dt, 0)
        local pts = {pos}

        for step = 1, 15 do
            vel = (vel + g) * 0.99
            pos = pos + vel * dt
            pts[step + 1] = pos
            if pos.Y <= 0.5 and vel.Y < 0 then break end
        end

        for i = 1, #segs do
            if pts[i] and pts[i+1] and Settings.PredictorLine then
                local p1, p2 = pts[i], pts[i+1]
                segs[i].Size = Vector3.new(0.2, 0.2, (p2 - p1).Magnitude)
                segs[i].CFrame = CFrame.lookAt((p1 + p2)/2, p2)
                segs[i].Transparency = 0.2 + (i/15) * 0.5
            else
                segs[i].Transparency = 1
            end
        end

        if Settings.PredictorLandMark and pts[#pts].Y <= 1 then
            marker.CFrame = CFrame.new(pts[#pts] * Vector3.new(1,0,1) + Vector3.new(0, 0.1, 0)) * CFrame.Angles(0, 0, math.pi/2)
            marker.Transparency = 0.3
        else
            marker.Transparency = 1
        end
    end)
end

