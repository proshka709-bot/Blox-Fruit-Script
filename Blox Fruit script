local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local Window = Rayfield:CreateWindow({
    Name            = "RSS — GK Hub v2",
    Icon            = 0,
    LoadingTitle    = "RSS GK Hub",
    LoadingSubtitle = "Smart Edition v2",
    Theme           = "Default",
    ConfigurationSaving = {
        Enabled    = true,
        FolderName = nil,
        FileName   = "RSS_GK_Config",
    },
    KeySystem = false,
})

-- ──────── TAB: REACH ────────

local ReachTab = Window:CreateTab("Reach", "maximize")
ReachTab:CreateSection("Hitbox")

ReachTab:CreateToggle({
    Name         = "Enable Reach",
    CurrentValue = false,
    Flag         = "ReachToggle",
    Callback     = function(v)
        if v then EnableReach() else DisableReach() end
    end,
})

ReachTab:CreateToggle({
    Name         = "Show Hitbox",
    CurrentValue = false,
    Flag         = "HitboxToggle",
    Callback     = function(v)
        ShowHitbox = v
        UpdateHitbox()
    end,
})

ReachTab:CreateSection("Size")

ReachTab:CreateSlider({
    Name         = "Size X",
    Range        = {1, 60},
    Increment    = 1,
    Suffix       = "",
    CurrentValue = 10,
    Flag         = "SizeX",
    Callback     = function(v)
        HitboxSize = Vector3.new(v, HitboxSize.Y, HitboxSize.Z)
        UpdateHitbox()
    end,
})

ReachTab:CreateSlider({
    Name         = "Size Y",
    Range        = {1, 60},
    Increment    = 1,
    Suffix       = "",
    CurrentValue = 10,
    Flag         = "SizeY",
    Callback     = function(v)
        HitboxSize = Vector3.new(HitboxSize.X, v, HitboxSize.Z)
        UpdateHitbox()
    end,
})

ReachTab:CreateSlider({
    Name         = "Size Z",
    Range        = {1, 60},
    Increment    = 1,
    Suffix       = "",
    CurrentValue = 10,
    Flag         = "SizeZ",
    Callback     = function(v)
        HitboxSize = Vector3.new(HitboxSize.X, HitboxSize.Y, v)
        UpdateHitbox()
    end,
})

-- ──────── TAB: GK ────────

local GkTab = Window:CreateTab("GK Features", "shield")
GkTab:CreateSection("Position")

GkTab:CreateDropdown({
    Name            = "Join as GK",
    Options         = {"Home GK", "Away GK"},
    CurrentOption   = {},
    MultipleOptions = false,
    Flag            = "JoinGK",
    Callback        = function(option)
        if not option or option == "" then return end
        local color = option == "Home GK" and BrickColor.new(23) or BrickColor.new(141)
        pcall(function()
            ReplicatedStorage
                :WaitForChild("Remotes")
                :WaitForChild("TeamChange")
                :FireServer(color, "Goalie")
        end)
        Rayfield:Notify({
            Title    = "GK Position",
            Content  = "Requested: " .. tostring(option),
            Duration = 3,
        })
    end,
})

GkTab:CreateSection("Auto Dive v2")

GkTab:CreateToggle({
    Name         = "Auto Dive",
    CurrentValue = false,
    Flag         = "DiveToggle",
    Callback     = function(v)
        if v then
            StartAutoDive()
            Rayfield:Notify({
                Title    = "Auto Dive",
                Content  = "Enabled — trajectory simulation, kick detection, adaptive timing",
                Duration = 4,
            })
        else
            StopAutoDive()
            Rayfield:Notify({
                Title    = "Auto Dive",
                Content  = "Disabled",
                Duration = 2,
            })
        end
    end,
})

-- ──────── TAB: PREDICTOR ────────

local PredTab = Window:CreateTab("Predictor", "activity")
PredTab:CreateSection("Ball Trajectory")

PredTab:CreateToggle({
    Name         = "Ball Predictor",
    CurrentValue = false,
    Flag         = "PredToggle",
    Callback     = function(v)
        if v then
            StartPredictor()
            Rayfield:Notify({
                Title    = "Predictor",
                Content  = string.format("Enabled (FPS: %d, auto-adjusted)", math.floor(currentFPS)),
                Duration = 3,
            })
        else
            StopPredictor()
        end
    end,
})

-- ──────── TAB: SETTINGS ────────

local SetTab = Window:CreateTab("Settings", "settings")
SetTab:CreateSection("General")

SetTab:CreateToggle({
    Name         = "Visual Effects",
    CurrentValue = true,
    Flag         = "VisualsToggle",
    Callback     = function(v)
        Settings.EnableVisuals = v
        if not v then UpdateHitbox() end
    end,
})

-- ═══════════════════════════════════════════════════════════
-- ИНИЦИАЛИЗАЦИЯ
-- ═══════════════════════════════════════════════════════════

CreateHitbox()
UpdateHitbox()

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1.5)
    cachedBall = nil

    CreateHitbox()
    UpdateHitbox()

    if IsReachEnabled then
        if ReachConn then ReachConn:Disconnect(); ReachConn = nil end
        if hitboxPulseConn then hitboxPulseConn:Disconnect(); hitboxPulseConn = nil end
        EnableReach()
    end

    if DiveActive then
        if DiveConn then DiveConn:Disconnect(); DiveConn = nil end
        task.wait(0.5)
        StartAutoDive()
    end
end)

Rayfield:Notify({
    Title    = "RSS GK Hub v2",
    Content  = "Loaded! All parameters are automatic.",
    Duration = 5,
})

print("[RSS GK] Smart Edition v2 loaded!")
