-- HITBOX / REACH (УЛУЧШЕН)
-- ============================================================

local function CreateHitbox()
    if RSSHitbox then
        pcall(function() RSSHitbox:Destroy() end)
        RSSHitbox = nil
    end
    local root = GetRoot()
    if not root then return end

    RSSHitbox              = Instance.new("BoxHandleAdornment")
    RSSHitbox.Name         = "RSSHitbox"
    RSSHitbox.AlwaysOnTop  = false
    RSSHitbox.ZIndex       = 10
    RSSHitbox.Color3       = Color3.fromRGB(0, 255, 100)
    RSSHitbox.Transparency = 1
    RSSHitbox.Size         = HitboxSize
    RSSHitbox.Adornee      = root
    RSSHitbox.Parent       = Workspace.Terrain
end

local function UpdateHitbox(show)
    if not RSSHitbox then return end
    local root = GetRoot()
    if not root then return end
    RSSHitbox.Size    = HitboxSize
    RSSHitbox.Adornee = root
    -- Учитываем настройку HitboxGlow
    local visible = show and IsReachEnabled and Settings.HitboxGlow
    RSSHitbox.Transparency = visible and 0.4 or 1
end

local function ReachLoop()
    local root = GetRoot()
    if not root or not RSSHitbox then return end
    RSSHitbox.Adornee = root

    local ball = FindBall()
    if not ball then return end

    local char = LocalPlayer.Character
    if not char then return end

    local ballPos = ball.Position
    local ballVel = ball.AssemblyLinearVelocity
    local baseReach = math.max(HitboxSize.X, HitboxSize.Y, HitboxSize.Z) / 2
    local reach = baseReach

    -- ★ Velocity Boost: увеличиваем рич при быстром мяче
    if Settings.ReachVelocityBoost and ballVel.Magnitude > 5 then
        local speedBonus = math.clamp(ballVel.Magnitude * 0.015, 0, 2.5)
        reach = reach + speedBonus
    end

    local distToBall = (ballPos - root.Position).Magnitude
    if distToBall > reach then return end

    -- Собираем части тела
    local parts = {}
    for _, part in ipairs(char:GetChildren()) do
        if part:IsA("BasePart") then
            parts[#parts + 1] = part
        end
    end

    -- ★ Умная сортировка: зависит от высоты мяча
    local ballRelHeight = ballPos.Y - root.Position.Y
    if ballRelHeight > 3 then
        -- Высокий мяч: приоритет верхним частям тела
        table.sort(parts, function(a, b)
            return a.Position.Y > b.Position.Y
        end)
    elseif ballRelHeight < -1 then
        -- Низкий мяч: приоритет нижним частям
        table.sort(parts, function(a, b)
            return a.Position.Y < b.Position.Y
        end)
    else
        -- Обычный: приоритет ближайшим частям
        table.sort(parts, function(a, b)
            return (a.Position - ballPos).Magnitude < (b.Position - ballPos).Magnitude
        end)
    end

    local touchCount = math.min(Settings.ReachTouchCount, #parts)
    for i = 1, touchCount do
        local part = parts[i]
        pcall(firetouchinterest, part, ball, 0)
        pcall(firetouchinterest, part, ball, 1)
        -- ★ Двойной touch для лучшей регистрации
        if Settings.ReachDoubleTap then
            pcall(firetouchinterest, part, ball, 0)
        end
    end
end

local function EnableReach()
    if ReachConn then return end
    IsReachEnabled = true
    if not RSSHitbox then CreateHitbox() end
    ReachConn = RunService.Heartbeat:Connect(ReachLoop)
    Notify("✅ Reach", "maximize", "Reach включён", 2)
end

local function DisableReach()
    if ReachConn then ReachConn:Disconnect(); ReachConn = nil end
    IsReachEnabled = false
    UpdateHitbox(false)
    Notify("❌ Reach", "minimize", "Reach выключен", 2)
end

-- ============================================================
-- AUTO DIVE — ПОЛНОСТЬЮ УЛУЧШЕН v2.0
-- ============================================================

-- Предсказание позиции мяча через dt секунд
local function PredictBallPos(ball, dt)
    local vel = ball.AssemblyLinearVelocity
    local pos = ball.Position
    local g   = Vector3.new(0, -196.2, 0)
    return pos + vel * dt + g * (dt * dt * 0.5)
end

-- ★ Мульти-фреймовое отслеживание скорости
local function TrackBallVelocity(vel)
    velocityHistory[#velocityHistory + 1] = {
        vel  = vel,
        time = tick(),
        mag  = vel.Magnitude,
    }
    while #velocityHistory > MAX_VEL_HISTORY do
        table.remove(velocityHistory, 1)
    end
end

-- ★ Улучшенная детекция удара с мульти-фреймовым анализом
local function DetectKick()
    local n = #velocityHistory
    if n < 2 then return false end

    local curr = velocityHistory[n]
    local prev = velocityHistory[n - 1]

    local accel     = (curr.vel - prev.vel).Magnitude
    local speedJump = curr.mag - prev.mag
    local sens      = Settings.DiveSensitivity

    -- Резкое ускорение
    if accel > (10 / sens) then return true end
    -- Резкий рост скорости
    if speedJump > (8 / sens) then return true end

    -- ★ Мульти-фреймовая проверка: среднее ускорение за 3 кадра
    if n >= 3 then
        local prev2 = velocityHistory[n - 2]
        local avgAccel = ((curr.vel - prev.vel).Magnitude + (prev.vel - prev2.vel).Magnitude) / 2
        if avgAccel > (7 / sens) then return true end
    end

    -- ★ Проверка смены направления (кто-то перехватил мяч)
    if n >= 2 then
        local dotDir = curr.vel.Unit:Dot(prev.vel.Unit)
        if dotDir < -0.3 and curr.mag > 8 then return true end
    end

    return false
end

local function GetDiveButtons()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    if not gui then return nil, nil end

    local leftBtn, rightBtn

    pcall(function()
        local ctrl  = gui:FindFirstChild("MobileCTRL")
        local frame = ctrl and ctrl:FindFirstChild("TouchControlFrame")
        local jump  = frame and frame:FindFirstChild("JumpButton")
        if jump then
            leftBtn  = jump:FindFirstChild("LeftDive")
            rightBtn = jump:FindFirstChild("RightDive")
        end
    end)
    if leftBtn and rightBtn then return leftBtn, rightBtn end

    leftBtn, rightBtn = nil, nil
    pcall(function()
        for _, obj in ipairs(gui:GetDescendants()) do
            if obj.Name == "LeftDive" and not leftBtn then leftBtn = obj end
            if obj.Name == "RightDive" and not rightBtn then rightBtn = obj end
            if leftBtn and rightBtn then break end
        end
    end)
    return leftBtn, rightBtn
end

local function FireButton(btn)
    if not btn then return end
    local ok, conns = pcall(getconnections, btn.MouseButton1Click)
    if ok and conns then
        for _, conn in ipairs(conns) do pcall(function() conn:Fire() end) end
        if #conns > 0 then return end
    end
    pcall(function() btn.MouseButton1Click:Fire() end)
end

local function TryJump()
    if not Settings.DiveAutoJump then return end
    local hum = GetHumanoid()
    if hum and hum:GetState() ~= Enum.HumanoidStateType.Jumping
          and hum:GetState() ~= Enum.HumanoidStateType.Freefall then
        hum.Jump = true
    end
end

-- ★ Улучшенная проверка удара
local function IsShot(ball, hrp)
    local vel    = ball.AssemblyLinearVelocity
    local velMag = vel.Magnitude
    local sens   = Settings.DiveSensitivity

    -- Минимальная скорость с учётом чувствительности
    if velMag < (12 / sens) then return false end

    local horizVel = Vector3.new(vel.X, 0, vel.Z)
    local horizMag = horizVel.Magnitude

    local ballHeight = ball.Position.Y - hrp.Position.Y
    if ballHeight < 1.5 and horizMag < (20 / sens) then return false end

    -- Направление к вратарю
    local toGK    = hrp.Position - ball.Position
    local toGKDir = Vector3.new(toGK.X, 0, toGK.Z)
    if toGKDir.Magnitude < 0.1 then return true end
    toGKDir = toGKDir.Unit

    local velDir = Vector3.new(vel.X, 0, vel.Z)
    if velDir.Magnitude < 0.1 then return false end
    velDir = velDir.Unit

    local dot = toGKDir:Dot(velDir)
    -- ★ С учётом чувствительности: ниже порог = раньше реакция
    if dot < (0.15 / sens) then return false end

    return true
end

local function StartAutoDive()
    if DiveConn then DiveConn:Disconnect(); DiveConn = nil end
    DiveActive       = true
    velocityHistory  = {}

    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp  = char:WaitForChild("HumanoidRootPart", 5)
    if not hrp then
        warn("❌ HumanoidRootPart не найден!")
        DiveActive = false
        return
    end

    local leftBtn  = nil
    local rightBtn = nil

    -- ★ Поиск кнопок в фоне с уведомлением
    task.spawn(function()
        for attempt = 1, 25 do
            leftBtn, rightBtn = GetDiveButtons()
            if leftBtn and rightBtn then
                Notify("✅ Дайв", "shield-check", "Кнопки найдены (попытка #" .. attempt .. ")", 2)
                break
            end
            task.wait(0.7)
        end
        if not leftBtn or not rightBtn then
            Notify("❌ Дайв", "alert-triangle", "Кнопки дайва не найдены!", 5)
        end
    end)

    local frameCounter = 0

    DiveConn = RunService.Heartbeat:Connect(function()
        if not leftBtn or not rightBtn then return end
        if not hrp or not hrp.Parent then return end

        -- ★ Режим производительности: пропускаем кадры
        if Settings.PerformanceMode then
            frameCounter = frameCounter + 1
            if frameCounter % 2 ~= 0 then return end
        end

        local ball = FindBall()
        if not ball then velocityHistory = {}; return end

        local vel    = ball.AssemblyLinearVelocity
        local velMag = vel.Magnitude

        -- ★ Отслеживание скорости мяча (мульти-фреймовое)
        TrackBallVelocity(vel)

        -- ★ Улучшенная детекция удара
        local wasKicked = DetectKick()

        -- Проверка: это удар?
        if not IsShot(ball, hrp) then return end

        local now = tick()
        local cooldown = wasKicked and 0.10 or 0.22
        if now - lastDiveTime < cooldown then return end

        local ballPos = ball.Position
        local hrpPos  = hrp.Position
        local dist    = (ballPos - hrpPos).Magnitude

        -- ★ Авто-дистанция с учётом агрессивного режима
        local baseMax = Settings.DiveAggressiveMode and 10 or 8
        local maxDist = math.clamp(baseMax + velMag * 0.25, 12, 35)
        if dist > maxDist then return end

        -- ★ Уверенность: дайвим только если отслеживали мяч достаточно
        if #velocityHistory < 2 then return end

        -- Время до прилёта
        local timeToArrive = dist / math.max(velMag, 1)
        local predictTime  = math.clamp(timeToArrive, 0.05, 0.5)

        -- ★ Мульти-шаговое предсказание: среднее из 2 точек
        local predicted1 = PredictBallPos(ball, predictTime)
        local predicted2 = PredictBallPos(ball, predictTime * 0.7)
        local predicted  = (predicted1 + predicted2) * 0.5

        local localPred  = hrp.CFrame:PointToObjectSpace(predicted)
        local predHeight = predicted.Y - hrpPos.Y

        if predHeight > 9 then return end -- слишком высоко

        lastDiveTime = now

        -- ★ Прыжок при высоком мяче (учитывает настройку)
        if predHeight > 1.2 then
            TryJump()
        end

        -- ★ Порог стороны: чем быстрее мяч, тем быстрее реакция
        local sideThreshold = math.clamp(0.6 - (velMag / 200) * Settings.DiveSensitivity, 0.08, 0.6)

        if localPred.X < -sideThreshold then
            FireButton(leftBtn)
        elseif localPred.X > sideThreshold then
            FireButton(rightBtn)
        else
            -- ★ Мяч по центру: реакция по настройке
            if Settings.DiveCenterReaction and velMag > 12 then
                TryJump()
                FireButton(leftBtn)
                FireButton(rightBtn)
            end
        end
    end)

    Notify("✅ Auto Dive", "shield", "Дайв 7v7 включён!", 3)
end

local function StopAutoDive()
    DiveActive = false
    if DiveConn then DiveConn:Disconnect(); DiveConn = nil end
    velocityHistory = {}
    Notify("❌ Auto Dive", "shield-off", "Дайв выключен", 2)
end

