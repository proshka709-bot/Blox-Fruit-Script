local function PredictBallPos(ball, dt)
    local vel = ball.AssemblyLinearVelocity
    local pos = ball.Position
    local g   = Vector3.new(0, -196.2, 0)
    return pos + vel * dt + g * (dt * dt * 0.5)
end

-- Улучшенное предсказание с учётом вращения мяча
local function PredictBallPosAdvanced(ball, dt)
    local vel = ball.AssemblyLinearVelocity
    local pos = ball.Position
    local g   = Vector3.new(0, -196.2, 0)

    -- Учитываем angular velocity для эффекта Magnus (упрощённый)
    local angVel = ball.AssemblyAngularVelocity
    local magnusEffect = Vector3.new(0, 0, 0)
    if angVel.Magnitude > 1 then
        magnusEffect = angVel:Cross(vel) * 0.0005 * dt
    end

    return pos + vel * dt + g * (dt * dt * 0.5) + magnusEffect
end

local function GetDiveButtons()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    if not gui then return nil, nil end

    local leftBtn, rightBtn
    local ok1 = pcall(function()
        local ctrl  = gui:FindFirstChild("MobileCTRL")
        local frame = ctrl and ctrl:FindFirstChild("TouchControlFrame")
        local jump  = frame and frame:FindFirstChild("JumpButton")
        if jump then
            leftBtn  = jump:FindFirstChild("LeftDive")
            rightBtn = jump:FindFirstChild("RightDive")
        end
    end)
    if ok1 and leftBtn and rightBtn then return leftBtn, rightBtn end

    leftBtn, rightBtn = nil, nil
    pcall(function()
        for _, obj in ipairs(gui:GetDescendants()) do
            if obj.Name == "LeftDive" and not leftBtn then leftBtn = obj end
            if obj.Name == "RightDive" and not rightBtn then rightBtn = obj end
            if leftBtn and rightBtn then break end
        end
    end)
    return leftBtn, rightBtn
end

local function FireButton(btn)
    if not btn then return end
    local ok, conns = pcall(getconnections, btn.MouseButton1Click)
    if ok and conns then
        for _, conn in ipairs(conns) do
            pcall(function() conn:Fire() end)
        end
        if #conns > 0 then return end
    end
    pcall(function() btn.MouseButton1Click:Fire() end)
end

local function TryJump()
    if not Settings.EnableJumpDive then return end
    local hum = GetHumanoid()
    if hum and hum:GetState() ~= Enum.HumanoidStateType.Jumping
          and hum:GetState() ~= Enum.HumanoidStateType.Freefall then
        hum.Jump = true
    end
end

-- Улучшенная детекция удара
local function IsShot(ball, hrp)
    local vel    = ball.AssemblyLinearVelocity
    local velMag = vel.Magnitude

    local minSpeed = Settings.DiveMinBallSpeed * (1 / Settings.DiveSensitivity)
    if velMag < minSpeed then return false end

    local horizVel = Vector3.new(vel.X, 0, vel.Z)
    local horizMag = horizVel.Magnitude

    local ballHeight = ball.Position.Y - hrp.Position.Y
    if ballHeight < 1.5 and horizMag < (20 / Settings.DiveSensitivity) then return false end

    local toGK    = (hrp.Position - ball.Position)
    local toGKDir = Vector3.new(toGK.X, 0, toGK.Z)
    if toGKDir.Magnitude < 0.1 then return true end
    toGKDir = toGKDir.Unit

    local velDir = Vector3.new(vel.X, 0, vel.Z)
    if velDir.Magnitude < 0.1 then return false end
    velDir = velDir.Unit

    local dot = toGKDir:Dot(velDir)
    local dotThreshold = math.clamp(0.15 / Settings.DiveSensitivity, 0.05, 0.3)
    if dot < dotThreshold then return false end

    return true
end

local prevBallVel    = nil
local prevBallSpeed  = 0
local consecutiveDives = 0
local lastDiveDirection = nil

local function StartAutoDive()
    if DiveConn then DiveConn:Disconnect(); DiveConn = nil end
    DiveActive       = true
    prevBallVel      = nil
    prevBallSpeed    = 0
    consecutiveDives = 0

    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp  = char:WaitForChild("HumanoidRootPart", 5)
    if not hrp then
        warn("❌ HumanoidRootPart не найден!")
        DiveActive = false
        return
    end

    CreateDiveIndicator()

    local leftBtn  = nil
    local rightBtn = nil

    task.spawn(function()
        for attempt = 1, 20 do
            leftBtn, rightBtn = GetDiveButtons()
            if leftBtn and rightBtn then
                print("✅ Кнопки дайва найдены с попытки #" .. attempt)
                break
            end
            task.wait(0.8)
        end
        if not leftBtn or not rightBtn then
            warn("❌ Кнопки дайва не найдены!")
        end
    end)

    DiveConn = RunService.Heartbeat:Connect(function()
        if not leftBtn or not rightBtn then return end
        if not hrp or not hrp.Parent then return end

        -- В режиме низкой производительности пропускаем кадры
        if Settings.LowPerformanceMode then
            if tick() % 0.05 < 0.016 then return end
        end

        local ball = FindBall()
        if not ball then prevBallVel = nil; prevBallSpeed = 0; return end

        local vel    = ball.AssemblyLinearVelocity
        local velMag = vel.Magnitude

        -- Детекция удара
        local wasKicked = false
        if prevBallVel then
            local speedJump = velMag - prevBallSpeed
            local accel     = (vel - prevBallVel).Magnitude
            local threshold = 12 / Settings.DiveReactionSpeed
            if accel > threshold or speedJump > (10 / Settings.DiveReactionSpeed) then
                wasKicked = true
                Stats.ShotsDetected += 1
            end
        end
        prevBallVel   = vel
        prevBallSpeed = velMag

        if not IsShot(ball, hrp) then return end

        local now = tick()
        local baseCooldown = wasKicked and 0.12 or 0.25
        local cooldown = baseCooldown / Settings.DiveReactionSpeed
        if now - lastDiveTime < cooldown then return end

        local ballPos = ball.Position
        local hrpPos  = hrp.Position
        local dist    = (ballPos - hrpPos).Magnitude

        local maxDist = math.clamp(8 + velMag * 0.25 * Settings.DiveSensitivity, 12, Settings.DiveMaxDistance)
        if dist > maxDist then return end

        local timeToArrive = dist / math.max(velMag, 1)
        local predictTime = math.clamp(timeToArrive, 0.03, 0.6)

        -- Используем улучшенное предсказание
        local predicted = PredictBallPosAdvanced(ball, predictTime)
        local localPred = hrp.CFrame:PointToObjectSpace(predicted)

        local predHeight = predicted.Y - hrpPos.Y
        if predHeight > 10 then return end

        lastDiveTime = now
        Stats.DivesPerformed += 1

        -- Высокий мяч: прыжок
        if predHeight > 1.2 then
            TryJump()
        end

        -- Адаптивный порог стороны
        local sideThreshold = math.clamp(
            (0.6 - (velMag / 200)) / Settings.DiveSensitivity,
            0.05, 0.6
        )

        local diveDirection = nil

        if localPred.X < -sideThreshold then
            FireButton(leftBtn)
            diveDirection = -hrp.CFrame.RightVector

            -- Двойной дайв при очень быстром мяче
            if Settings.EnableDoubleDive and velMag > 50 then
                task.delay(0.05, function()
                    FireButton(leftBtn)
                end)
            end
        elseif localPred.X > sideThreshold then
            FireButton(rightBtn)
            diveDirection = hrp.CFrame.RightVector

            if Settings.EnableDoubleDive and velMag > 50 then
                task.delay(0.05, function()
                    FireButton(rightBtn)
                end)
            end
        else
            -- Мяч по центру
            if Settings.EnableCenterDive and velMag > 15 then
                TryJump()
                -- Выбираем сторону на основе минимального смещения
                if localPred.X < 0 then
                    FireButton(leftBtn)
                    diveDirection = -hrp.CFrame.RightVector
                else
                    FireButton(rightBtn)
                    diveDirection = hrp.CFrame.RightVector
                end
            end
        end

        -- Показываем индикатор
        if diveDirection then
            ShowDiveIndicator(diveDirection, 0.5)
            lastDiveDirection = diveDirection
        end
    end)

