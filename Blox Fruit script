-- BALL PREDICTOR — УЛУЧШЕН
-- ============================================================

local predConn    = nil
local curveFolder = nil

local function StartPredictor()
    local cfg = {
        gravity       = 196.2,
        bounceDamping = 0.68,
        groundHeight  = 0,
        airResistance = 0.99,
        friction      = 0.85,
        segmentCount  = Settings.PredictorSegments,
        segmentTrans  = 0.25,
        maxTime       = Settings.PredictorMaxTime,
        dt            = Settings.LowPerformanceMode and 0.06 or 0.04,
        minSpeed      = Settings.PredictorMinSpeed,
        updateEvery   = Settings.LowPerformanceMode and 5 or Settings.PredictorUpdateRate,
        colorCurve    = Settings.PredictorColor,
        colorLand     = Settings.PredictorLandColor,
    }

    if curveFolder then
        pcall(function() curveFolder:Destroy() end)
        curveFolder = nil
    end
    curveFolder        = Instance.new("Folder")
    curveFolder.Name   = "GK_Predictor"
    curveFolder.Parent = Workspace

    local segs = {}
    for i = 1, cfg.segmentCount do
        local s = Instance.new("Part")
        s.Anchored    = true; s.CanCollide  = false; s.CastShadow = false
        s.Material    = Enum.Material.Neon
        s.Color       = cfg.colorCurve
        s.Transparency = 1
        s.Size        = Vector3.new(0.25, 0.25, 1)
        s.Parent      = curveFolder
        segs[i] = s
    end

    local marker = Instance.new("Part")
    marker.Anchored    = true; marker.CanCollide = false; marker.CastShadow = false
    marker.Material    = Enum.Material.Neon
    marker.Color       = cfg.colorLand
    marker.Transparency = 1
    marker.Size        = Vector3.new(5, 0.15, 5)
    marker.Shape       = Enum.PartType.Cylinder
    marker.Parent      = curveFolder

    -- Дополнительный маркер — крест на месте приземления
    local crossMarker1 = Instance.new("Part")
    crossMarker1.Anchored    = true; crossMarker1.CanCollide = false; crossMarker1.CastShadow = false
    crossMarker1.Material    = Enum.Material.Neon
    crossMarker1.Color       = cfg.colorLand
    crossMarker1.Transparency = 1
    crossMarker1.Size        = Vector3.new(4, 0.2, 0.4)
    crossMarker1.Parent      = curveFolder

    local crossMarker2 = crossMarker1:Clone()
    crossMarker2.Parent = curveFolder

    local function Simulate(startPos, startVel)
        local pts = {}
        local pos = startPos
        local vel = startVel
        local gdt = Vector3.new(0, -cfg.gravity * cfg.dt, 0)
        local bounces = 0
        local maxSteps = math.floor(cfg.maxTime / cfg.dt)

        for step = 1, maxSteps do
            vel = (vel + gdt) * cfg.airResistance
            pos = pos + vel * cfg.dt
            pts[step] = pos

            if pos.Y <= cfg.groundHeight and vel.Y < 0 then
                pos = Vector3.new(pos.X, cfg.groundHeight, pos.Z)
                vel = Vector3.new(vel.X * cfg.friction, -vel.Y * cfg.bounceDamping, vel.Z * cfg.friction)
                bounces += 1
                if bounces >= 3 or vel.Magnitude < 2 then break end
            end

            if vel.Magnitude < 0.5 then break end
        end
        return pts
    end

    local frame = 0
    predConn = RunService.Heartbeat:Connect(function()
        frame += 1
        if frame % cfg.updateEvery ~= 0 then return end

        if not Settings.EnableVisualEffects or not Settings.EnablePredictorTrail then
            for _, s in ipairs(segs) do s.Transparency = 1 end
            marker.Transparency = 1
            crossMarker1.Transparency = 1
            crossMarker2.Transparency = 1
            return
        end

        local ball = FindBall()
        if not ball or ball.AssemblyLinearVelocity.Magnitude < cfg.minSpeed then
            for _, s in ipairs(segs) do s.Transparency = 1 end
            marker.Transparency = 1
            crossMarker1.Transparency = 1
            crossMarker2.Transparency = 1
            return
        end

        local pts = Simulate(ball.Position, ball.AssemblyLinearVelocity)
        local n   = #pts
        if n < 2 then
            for _, s in ipairs(segs) do s.Transparency = 1 end
            marker.Transparency = 1
            crossMarker1.Transparency = 1
            crossMarker2.Transparency = 1
            return
        end

        local step = (n - 1) / cfg.segmentCount
        for i = 1, cfg.segmentCount do
            local idx  = math.floor((i - 1) * step) + 1
            local idx2 = math.min(idx + 1, n)
            local p1, p2 = pts[idx], pts[idx2]
            local dist = (p2 - p1).Magnitude
            if dist > 0.01 then
                -- Градиент цвета от бирюзового к красному
                local t = i / cfg.segmentCount
                local r = math.floor(cfg.colorCurve.R * 255 * (1 - t) + 255 * t)
                local g = math.floor(cfg.colorCurve.G * 255 * (1 - t) + 80 * t)
                local b = math.floor(cfg.colorCurve.B * 255 * (1 - t) + 80 * t)
                segs[i].Color        = Color3.fromRGB(r, g, b)
                segs[i].Size         = Vector3.new(0.25 - t * 0.1, 0.25 - t * 0.1, dist)
                segs[i].CFrame       = CFrame.lookAt((p1 + p2) * 0.5, p2)
                segs[i].Transparency = cfg.segmentTrans + t * 0.3
            else
                segs[i].Transparency = 1
            end
        end

        local landPos = nil
        for i = 2, n do
            if pts[i].Y <= cfg.groundHeight + 0.3 and pts[i-1].Y > cfg.groundHeight + 0.3 then
                local dy = pts[i].Y - pts[i-1].Y
                if math.abs(dy) > 0.001 then
                    local t = math.clamp((cfg.groundHeight - pts[i-1].Y) / dy, 0, 1)
                    landPos = pts[i-1]:Lerp(pts[i], t)
                end
                break
            end
        end

        if landPos and Settings.EnableLandingMarker then
            local pulse = 5 + math.sin(tick() * 4) * 1.5
            marker.Size        = Vector3.new(pulse, 0.15, pulse)
            marker.CFrame      = CFrame.new(landPos + Vector3.new(0, 0.1, 0)) * CFrame.Angles(0, 0, math.pi / 2)
            marker.Transparency = 0.3

            -- Крест
            crossMarker1.CFrame       = CFrame.new(landPos + Vector3.new(0, 0.15, 0))
            crossMarker1.Transparency  = 0.35
            crossMarker2.CFrame       = CFrame.new(landPos + Vector3.new(0, 0.15, 0)) * CFrame.Angles(0, math.pi / 4, 0)
            crossMarker2.Transparency  = 0.35
        else
            marker.Transparency = 1
            crossMarker1.Transparency = 1
            crossMarker2.Transparency = 1
        end
    end)
end

local function StopPredictor()
    if predConn then predConn:Disconnect(); predConn = nil end
    if curveFolder then
        pcall(function() curveFolder:Destroy() end)
        curveFolder = nil
    end
end

