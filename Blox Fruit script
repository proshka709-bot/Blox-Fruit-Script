    end
})

-- ──────── ВКЛАДКА: SETTINGS ────────

local SettingsTab   = Window:Tab({ Title = "Settings", Icon = "settings" })
local VisualSection = SettingsTab:Section({ Title = "Общие" })

VisualSection:Toggle({
    Title    = "Visual Effects",
    Desc     = "Все визуальные эффекты (хитбокс, предиктор, маркер)",
    Default  = true,
    Callback = function(v)
        Settings.EnableVisualEffects = v
        if not v then UpdateHitbox() end
    end
})

VisualSection:Toggle({
    Title    = "Notifications",
    Desc     = "Уведомления хаба",
    Default  = true,
    Callback = function(v)
        Settings.EnableNotifications = v
    end
})

