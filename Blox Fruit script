-- ============================================================
-- НАПАДАЮЩИЙ — AUTO FUNCTIONS
-- ============================================================

local PlayerSettings = {
    AutoShootDistance   = 15,
    AutoShootPower      = true,
    AutoDekeDistance    = 8,
    AutoTackleDistance  = 6,
}

local lastShootTime  = 0
local lastDekeTime   = 0
local lastTackleTime = 0
local AutoShootConn  = nil
local AutoDekeConn   = nil
local AutoTackleConn = nil

-- Авто-удар: бьёт когда мяч рядом
local function StartAutoShoot()
    if AutoShootConn then AutoShootConn:Disconnect() end
    AutoShootConn = RunService.Heartbeat:Connect(function()
        local root = GetRoot()
        local ball = FindBall()
        if not root or not ball then return end

        local dist = (ball.Position - root.Position).Magnitude
        if dist > PlayerSettings.AutoShootDistance then return end

        local now = tick()
        if now - lastShootTime < 1.0 then return end -- кулдаун 1 сек
        lastShootTime = now

        if PlayerSettings.AutoShootPower then
            FireButton("PowerShoot")
        else
            -- Обычный удар через Pass если нет PowerShoot
            FireButton("Pass")
        end
    end)
end

-- Авто-финт: делает финт когда рядом соперник с мячом
local function StartAutoDeke()
    if AutoDekeConn then AutoDekeConn:Disconnect() end
    AutoDekeConn = RunService.Heartbeat:Connect(function()
        local root = GetRoot()
        local ball = FindBall()
        if not root or not ball then return end

        -- Финт только если мяч у нас (рядом)
        local distToBall = (ball.Position - root.Position).Magnitude
        if distToBall > 5 then return end

        -- Проверяем есть ли рядом соперник
        local nearEnemy = false
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local enemyRoot = player.Character:FindFirstChild("HumanoidRootPart")
                if enemyRoot then
                    local dist = (enemyRoot.Position - root.Position).Magnitude
                    if dist < PlayerSettings.AutoDekeDistance then
                        nearEnemy = true
                        break
                    end
                end
            end
        end

        if not nearEnemy then return end

        local now = tick()
        if now - lastDekeTime < 1.5 then return end
        lastDekeTime = now

        FireButton("Deke")
    end)
end

-- Авто-подкат: делает подкат когда соперник с мячом рядом
local function StartAutoTackle()
    if AutoTackleConn then AutoTackleConn:Disconnect() end
    AutoTackleConn = RunService.Heartbeat:Connect(function()
        local root = GetRoot()
        local ball = FindBall()
        if not root or not ball then return end

        -- Подкат только если мяч НЕ у нас
        local distToBall = (ball.Position - root.Position).Magnitude
        if distToBall < 5 then return end -- мяч рядом = наш, не надо подкатывать

        -- Проверяем есть ли соперник с мячом рядом
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local enemyRoot = player.Character:FindFirstChild("HumanoidRootPart")
                if enemyRoot then
                    local distToEnemy = (enemyRoot.Position - root.Position).Magnitude
                    local enemyDistToBall = (ball.Position - enemyRoot.Position).Magnitude

                    -- Соперник рядом И у него мяч
                    if distToEnemy < PlayerSettings.AutoTackleDistance and enemyDistToBall < 6 then
                        local now = tick()
                        if now - lastTackleTime < 2.0 then return end
                        lastTackleTime = now
                        FireButton("Tackle")
                        break
                    end
                end
            end
        end
    end)
end

