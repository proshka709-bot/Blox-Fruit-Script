local function GetRoot()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function GetHumanoid()
    local char = LocalPlayer.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

-- Расширенный список названий мяча для разных игр
local BALL_NAMES = {
    "ball", "TPS", "PSoccerBall", "Soccer Ball", "Football",
    "SoccerBall", "Ball", "soccer_ball", "GameBall", "MatchBall",
    "Soccerball", "futbol", "Futbol", "ballon", "SB", "fb"
}

local function FindBall()
    local now = tick()
    -- Быстрая проверка кеша с таймаутом
    if cachedBall and cachedBall.Parent and cachedBall:IsA("BasePart")
       and (now - lastBallCacheTime) < BALL_CACHE_DURATION then
        return cachedBall
    end
    cachedBall = nil

    for _, name in ipairs(BALL_NAMES) do
        local b = Workspace:FindFirstChild(name, true)
        if b and b:IsA("BasePart") then
            cachedBall = b
            lastBallCacheTime = now
            return b
        end
    end
    return nil
end

local function isInFansTeam()
    local team = LocalPlayer.Team
    if not team then return true end
    local n = team.Name:lower()
    return n == "fans" or n == "spectators" or n == "spectator" or n == "lobby"
end

local function GetTeamChangeRemote()
    local remotes = ReplicatedStorage:FindFirstChild("Remotes")
    return remotes and remotes:FindFirstChild("TeamChange")
end

local function ReadStringValue(obj)
    if not obj then return nil end
    if typeof(obj) == "string" then return obj end
    if typeof(obj) == "Instance" then
        if obj:IsA("StringValue") then return obj.Value end
        if obj:IsA("IntValue") or obj:IsA("NumberValue") then return tostring(obj.Value) end
    end
    return nil
end

local function SearchRoleInObject(obj, keys)
    if not obj or typeof(obj) ~= "Instance" then return nil end
    for _, k in ipairs(keys) do
        local attr = obj:GetAttribute(k)
        if typeof(attr) == "string" and attr ~= "" then return attr end
        local v = ReadStringValue(obj:FindFirstChild(k))
        if v and v ~= "" then return v end
    end
    return nil
end

local function GetPlayerRoleString(plr)
    if not plr then return nil end
    local keys = {"Position", "Role", "POS", "Pos", "Class", "GameRole", "TeamRole", "PlayerRole"}

    -- Атрибуты игрока
    for _, k in ipairs(keys) do
        local attr = plr:GetAttribute(k)
        if typeof(attr) == "string" and attr ~= "" then return attr end
    end

    -- leaderstats
    local result = SearchRoleInObject(plr:FindFirstChild("leaderstats"), keys)
    if result then return result end

    -- Дочерние объекты игрока
    for _, k in ipairs(keys) do
        local v = ReadStringValue(plr:FindFirstChild(k))
        if v and v ~= "" then return v end
    end

    -- Персонаж
    local char = plr.Character
    if char then
        result = SearchRoleInObject(char, keys)
        if result then return result end
    end
    return nil
end

local GK_PATTERNS = {
    "goalie", "gk", "goalkeeper", "keeper", "вратарь", "голкипер", "portero", "gardien"
}

local function IsGoalkeeperRole(role)
    if not role or role == "" then return false end
    local lower = string.lower(role)
    for _, pattern in ipairs(GK_PATTERNS) do
        if lower == pattern or lower:find(pattern, 1, true) then return true end
    end
    return false
end

local function IsPlayerGoalkeeper(plr)
    return IsGoalkeeperRole(GetPlayerRoleString(plr))
end

local function IsLocalPlayerGoalkeeper()
    return IsPlayerGoalkeeper(LocalPlayer)
end

local function GetTeamBrickColor(option)
    return option == "Home GK" and BrickColor.new(23) or BrickColor.new(141)
end

local function IsGKSlotFree(option)
    local targetColor = GetTeamBrickColor(option)
    local anyRoleInfo = false
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.TeamColor == targetColor then
            local role = GetPlayerRoleString(plr)
            if role and role ~= "" then
                anyRoleInfo = true
                if IsGoalkeeperRole(role) then return false, true end
            end
        end
    end
    return true, anyRoleInfo
end

